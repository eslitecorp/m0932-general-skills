{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SKILL.md frontmatter",
  "type": "object",
  "required": ["name", "description", "tags"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "kebab-case skill identifier"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "一句話說明，需包含觸發語句"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "分類標籤"
    }
  }
}
